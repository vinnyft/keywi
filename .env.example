# ============================================================
# Keywi — modèle de variables d'environnement
# Copier vers .env.local puis compléter.
# Les valeurs Supabase ci-dessous sont celles de la stack locale
# (identiques pour tout le monde, affichées par `supabase status`).
# ============================================================

# Supabase (local)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# URL publique du site (liens dans les emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (mode test) — clés sk_test_/pk_test_ depuis dashboard.stripe.com
# Laisser vide pour utiliser le paiement simulé (aucun compte requis en local)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — clé re_... depuis resend.com
# Laisser vide pour journaliser les emails dans la console du serveur
RESEND_API_KEY=
EMAIL_FROM=Keywi <notifications@keywi.fr>

# Tâches planifiées — protège /api/cron/*
# Vide en local (les routes restent appelables à la main pour tester).
# EN PRODUCTION : mettre une valeur longue et aléatoire, sinon
# n'importe qui peut déclencher les relances et la génération de codes.
#   openssl rand -base64 32
CRON_SECRET=
